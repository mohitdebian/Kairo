","text":"5715"},"Replace `··················<span·className=\"text-[12px]·font-semibold·tracking-wide·flex-1·truncate·text-white\">{folder.name}` with `····················<span·className=\"text-[12px]·font-semibold·tracking-wide·flex-1·truncate·text-white\">⏎······················{folder.name}⏎····················`",{"range":"7242","text":"7243"},"Replace `················` with `··················`",{"range":"7244","text":"5944"},{"range":"7245","text":"5715"},{"range":"7246","text":"5715"},{"range":"7247","text":"5789"},"Replace `··············const·ws·=·store.workspaces.find(w` with `················const·ws·=·store.workspaces.find((w)`",{"range":"7248","text":"7249"},{"range":"7250","text":"5715"},{"range":"7251","text":"5915"},"Replace `<div·className=\"w-4·h-4·rounded-full·shadow-2xl\"·style={{·backgroundColor:·ws.color·}}` with `··<div⏎····················className=\"w-4·h-4·rounded-full·shadow-2xl\"⏎····················style={{·backgroundColor:·ws.color·}}⏎·················`",{"range":"7252","text":"7253"},{"range":"7254","text":"5715"},{"range":"7255","text":"5715"},["7256","7257"],"React Hook React.useMemo has a missing dependency: 'activeTab'. Either include it or remove the dependency array.",["7258"],["7259"],["7260","7261"],{"range":"7262","text":"5859"},{"range":"7263","text":"5715"},{"range":"7264","text":"5715"},{"range":"7265","text":"5715"},{"range":"7266","text":"6046"},{"range":"7267","text":"5710"},"Replace `·e.stopPropagation();·setIsOpen(!isOpen)` with `⏎··········e.stopPropagation()⏎··········setIsOpen(!isOpen)⏎·······`",{"range":"7268","text":"7269"},{"range":"7270","text":"6910"},"Replace `<div·id=\"site-settings-popover\"·className=\"fixed·z-[9999]\"` with `··<div⏎············id=\"site-settings-popover\"⏎············className=\"fixed·z-[9999]\"⏎···········`",{"range":"7271","text":"7272"},"Replace `··········` with `··············`",{"range":"7273","text":"5979"},"react-hooks/refs","Error: Cannot access refs during render\n\nReact refs are values that are not needed for rendering. Refs should only be accessed outside of render, such as in event handlers or effects. Accessing a ref value (the `current` property) during render can cause your component not to update as expected (https://react.dev/reference/react/useRef).\n\n/tmp/workspace/mohitdebian/Kairo/src/renderer/src/components/Sidebar/SiteSettingsPopover.tsx:76:17\n  74 |       {isOpen && typeof document !== 'undefined' && ReactDOM.createPortal(\n  75 |         <div id=\"site-settings-popover\" className=\"fixed z-[9999]\" style={{\n> 76 |           top: (buttonRef.current?.getBoundingClientRect().bottom || 0) + 10,\n     |                 ^^^^^^^^^^^^^^^^^ Cannot access ref value during render\n  77 |           left: buttonRef.current?.getBoundingClientRect().left || 0\n  78 |         }}>\n  79 |           <motion.div ","Error: Cannot access refs during render\n\nReact refs are values that are not needed for rendering. Refs should only be accessed outside of render, such as in event handlers or effects. Accessing a ref value (the `current` property) during render can cause your component not to update as expected (https://react.dev/reference/react/useRef).\n\n/tmp/workspace/mohitdebian/Kairo/src/renderer/src/components/Sidebar/SiteSettingsPopover.tsx:76:17\n  74 |       {isOpen && typeof document !== 'undefined' && ReactDOM.createPortal(\n  75 |         <div id=\"site-settings-popover\" className=\"fixed z-[9999]\" style={{\n> 76 |           top: (buttonRef.current?.getBoundingClientRect().bottom || 0) + 10,\n     |                 ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ Cannot access ref value during render\n  77 |           left: buttonRef.current?.getBoundingClientRect().left || 0\n  78 |         }}>\n  79 |           <motion.div ","Error: Cannot access refs during render\n\nReact refs are values that are not needed for rendering. Refs should only be accessed outside of render, such as in event handlers or effects. Accessing a ref value (