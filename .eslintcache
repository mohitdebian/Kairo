Performance`",{"range":"6690","text":"6691"},{"range":"6692","text":"6656"},"Replace `Automatically·free·memory·from·inactive·tabs` with `⏎····················Automatically·free·memory·from·inactive·tabs⏎··················`",{"range":"6693","text":"6694"},{"range":"6695","text":"5710"},"Replace `·className={`absolute·top-0.5·left-0.5·w-4·h-4·rounded-full·bg-white·transition-transform·${store.sleepingTabsEnabled·?·'translate-x-5'·:·'translate-x-0'}`}` with `⏎····················className={`absolute·top-0.5·left-0.5·w-4·h-4·rounded-full·bg-white·transition-transform·${store.sleepingTabsEnabled·?·'translate-x-5'·:·'translate-x-0'}`}⏎·················`",{"range":"6696","text":"6697"},{"range":"6698","text":"5710"},"Replace `Minutes·of·inactivity·before·sleeping` with `⏎······················Minutes·of·inactivity·before·sleeping⏎····················`",{"range":"6699","text":"6700"},{"range":"6701","text":"5710"},"Replace `·width=\"10\"·height=\"6\"·viewBox=\"0·0·10·6\"·fill=\"none\"·xmlns=\"http://www.w3.org/2000/svg\"` with `⏎························width=\"10\"⏎························height=\"6\"⏎························viewBox=\"0·0·10·6\"⏎························fill=\"none\"⏎························xmlns=\"http://www.w3.org/2000/svg\"⏎······················`",{"range":"6702","text":"6703"},"Replace `·d=\"M1·1L5·5L9·1\"·stroke=\"currentColor\"·strokeWidth=\"1.5\"·strokeLinecap=\"round\"·strokeLinejoin=\"round\"` with `⏎··························d=\"M1·1L5·5L9·1\"⏎··························stroke=\"currentColor\"⏎··························strokeWidth=\"1.5\"⏎··························strokeLinecap=\"round\"⏎··························strokeLinejoin=\"round\"⏎························`",{"range":"6704","text":"6705"},"Replace `About·Kairo</h3>` with `⏎··············About·Kairo`",{"range":"6706","text":"6707"},{"range":"6708","text":"6656"},{"range":"6709","text":"5710"},"Replace `Auto-Suggest·Tab·Groups` with `⏎······················Auto-Suggest·Tab·Groups⏎····················`",{"range":"6710","text":"6711"},"Replace `Show·a·suggestion·banner·when·you·have·4+·ungrouped·tabs.` with `⏎······················Show·a·suggestion·banner·when·you·have·4+·ungrouped·tabs.⏎····················`",{"range":"6712","text":"6713"},{"range":"6714","text":"5710"},"Replace `·className={`absolute·top-0.5·left-0.5·w-4·h-4·rounded-full·bg-white·transition-transform·${aiStore.autoSuggestEnabled·?·'translate-x-5'·:·'translate-x-0'}`}` with `⏎······················className={`absolute·top-0.5·left-0.5·w-4·h-4·rounded-full·bg-white·transition-transform·${aiStore.autoSuggestEnabled·?·'translate-x-5'·:·'translate-x-0'}`}⏎···················`",{"range":"6715","text":"6716"},"Insert `⏎·················`",{"range":"6717","text":"6718"},{"range":"6719","text":"5710"},{"range":"6720","text":"5884"},"Replace `·href=\"https://aistudio.google.com/app/apikey\"·target=\"_blank\"·rel=\"noreferrer\"·className=\"text-xs·text-purple-400·hover:text-purple-300·hover:underline·transition-colors\"` with `⏎····················href=\"https://aistudio.google.com/app/apikey\"⏎····················target=\"_blank\"⏎····················rel=\"noreferrer\"⏎····················className=\"text-xs·text-purple-400·hover:text-purple-300·hover:underline·transition-colors\"⏎··················`",{"range":"6721","text":"6722"},{"range":"6723","text":"5710"},{"range":"6724","text":"5710"},"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/tmp/workspace/mohitdebian/Kairo/src/renderer/src/components/Sidebar/AddressBar.tsx:33:7\n  31 |   useEffect(() => {\n  32 |     if (!isFocused) {\n> 33 |       setInputValue(primaryActiveTab?.url === 'dashboard' ? '' : (primaryActiveTab?.url || ''))\n     |       ^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  34 |     }\n  35 |   }, [primaryActiveTab?.url, primaryActiveTab?.id, isFocused])\n  36 |","Replace `(primaryActiveTab?.url·||·'')` with `primaryActiveTab?.url·||·''`",{"range":"6725","text":"6726"},{"range":"6727","text":"6030"},{"range":"6728","text":"6216"},{"range":"6729","text":"5710"},{"range":"6730","text":"6480"},"Replace `m` with `(m)`",{"range":"6731","text":"6732"},{"range":"6733","text":"5710"},{"range":"6734","text":"5710"},"Error: Cannot call impure function during render\n\n`Date.now` is an impure function. Calling an impure function can produce unstable results that update unpredictably when the component happens to re-render. (https://react.dev/reference/rules/components-and-hooks-must-be-pure#components-and-hooks-must-be-idempotent).\n\n/tmp/workspace/mohitdebian/Kairo/src/renderer/src/components/Sidebar/AddressBar.tsx:77:33\n  75 |         \n  76 |         // Recency (max 200)\n> 77 |         const daysSinceVisit = (Date.now() - entry.lastVisitAt) / (1000 * 60 * 60 * 24)\n     |                                 ^^^^^^^^^^ Cannot call impure function\n  78 |         if (daysSinceVisit < 1) score += 200\n  79 |         else if (daysSinceVisit < 7) score += 100\n  80 |         else if (daysSinceVisit < 30) score += 50",{"range":"6735","text":"5710"},"Replace `entry.url.toLowerCase().replace(/^https?:\\/\\/(www\\.)?/,·'').startsWith(query))` with `⏎··········entry.url⏎············.toLowerCase()⏎············.replace(/^https?:\\/\\/(www\\.)?/,·'')⏎············.startsWith(query)⏎········)⏎·········`",{"range":"6736","text":"6737"},"Replace `·searchEngine·===·'google'·?·`https://google.com/search?q=${encodeURIComponent(inputValue)}`` with `⏎··········searchEngine·===·'google'⏎············?·`https://google.com/search?q=${encodeURIComponent(inputValue)}`⏎···········`",{"range":"6738","text":"6739"},"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/tmp/workspace/mohitdebian/Kairo/src/renderer/src/components/Sidebar/AddressBar.tsx:116:5\n  114 |\n  115 |   useEffect(() => {\n> 116 |     setSelectedIndex(0)\n      |     ^^^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  117 |   }, [suggestions.length, inputValue])\n  118 |\n  119 |   const navigateTo = (url: string, isTab: boolean, tabId?: string) => {",{"range":"6740","text":"5710"},"Replace `!finalUrl.startsWith('http://')·&&·!finalUrl.startsWith('https://')·&&·!finalUrl.includes('localhost')·&&·finalUrl.includes('.')` with `⏎········!finalUrl.startsWith('http://')·&&⏎········!finalUrl.startsWith('https://')·&&⏎········!finalUrl.includes('localhost')·&&⏎········finalUrl.includes('.')⏎······`",{"range":"6741","text":"6742"},"Replace `·searchEngine·===·'google'·⏎` with `⏎··········searchEngine·===·'google'⏎··`",{"range":"6743","text":"6744"},{"range":"6745","text":"5912"},{"range":"6746","text":"5710"},{"range":"6747","text":"6318"},{"range":"6748","text":"6318"},{"range":"6749","text":"6726"},{"range":"6750","text":"6289"},"Replace `\"w-full·bg-white/[0.02]·border·border-white/5·rounded-xl·h-9·flex·items-center·shadow-inner·transition-all·duration-200\"` with `··'w-full·bg-white/[0.02]·border·border-white/5·rounded-xl·h-9·flex·items-center·shadow-inner·transition-all·duration-200'`",{"range":"6751","text":"6752"},"Replace `········isFocused·?·\"border-[var(--color-accent)]/50·bg-black/40·ring-1·ring-[var(--color-accent)]/30\"·:·\"hover:bg-white/[0.04]\"` with `··········isFocused⏎············?·'border-[var(--color-accent)]/50·bg-black/40·ring-1·ring-[var(--color-accent)]/30'⏎············:·'hover:bg-white/[0.04]'`",{"range":"6753","text":"6754"},"Replace `······)}` with `········)}⏎······`",{"range":"6755","text":"6756"},{"range":"6757","text":"5710"},{"range":"6758","text":"5710"},{"range":"6759","text":"5710"},{"range":"6760","text":"5710"},{"range":"6761","text":"5710"},{"range":"6762","text":"5710"},{"range":"6763","text":"5710"},{"range":"6764","text":"5710"},{"range":"6765","text":"5710"},"Replace `\"flex·items-center·gap-3·px-3·py-2·rounded-lg·cursor-pointer·transition-colors\"` with `'flex·items-center·gap-3·px-3·py-2·rounded-lg·cursor-pointer·transition-colors'`",{"range":"6766","text":"6767"},"Replace `\"bg-[var(--color-accent)]/20\"·:·\"hover:bg-white/5\"` with `'bg-[var(--color-accent)]/20'·:·'hover:bg-white/5'`",{"range":"6768","text":"6769"},"Delete `··················`",{"range":"6770","text":"5710"},"Replace `Switch·to·Tab` with `⏎························Switch·to·Tab⏎······················`",{"range":"6771","text":"6772"},{"range":"6773","text":"5710"},"Replace `·size={14}·className=\"text-[var(--color-accent)]·flex-shrink-0·opacity-50\"` with `⏎······················size={14}⏎······················className=\"text-[var(--color-accent)]·flex-shrink-0·opacity-50\"⏎···················`",{"range":"6774","text":"6775"},{"range":"6776","text":"5710"},{"range":"6777","text":"5710"},{"range":"6778","text":"5710"},{"range":"6779","text":"5710"},{"range":"6780","text":"5710"},{"range":"6781","text":"5710"},{"range":"6782","text":"5710"},{"range":"6783","text":"5710"},["6784","6785"],{"range":"6786","text":"5710"},{"range":"6787","text":"5710"},{"range":"6788","text":"5710"},{"range":"6789","text":"5710"},"Replace `\"flex·items-center·gap-2·px-2·py-1.5·rounded-lg·text-text-secondary·transition-colors·cursor-pointer·group\"` with `'flex·items-center·gap-2·px-2·py-1.5·rounded-lg·text-text-secondary·transition-colors·cursor-pointer·group'`",{"range":"6790","text":"6791"},"Replace `·?·\"bg-[var(--color-accent)]/20·text-text-primary·ring-1·ring-[var(--color-accent)]\"·:·\"hover:bg-white/5·hover:text-text-primary\"` with `⏎············?·'bg-[var(--color-accent)]/20·text-text-primary·ring-1·ring-[var(--color-accent)]'⏎············:·'hover:bg-white/5·hover:text-text-primary'`",{"range":"6792","text":"6793"},"Replace `·size={14}·className=\"group-hover:text-[var(--color-accent)]·transition-colors\"` with `⏎············size={14}⏎············className=\"group-hover:text-[var(--color-accent)]·transition-colors\"⏎·········`",{"range":"6794","text":"6795"},{"range":"6796","text":"5710"},"Replace `{folder.name}` with `⏎············{folder.name}⏎··········`",{"range":"6797","text":"6798"},{"range":"6799","text":"6162"},{"range":"6800","text":"6162"},{"range":"6801","text":"6162"},{"range":"6802","text":"6164"},{"range":"6803","text":"6162"},"Replace `state·=>·state.tabs.find(t` with `(state)·=>·state.tabs.find((t)`",{"range":"6804","text":"6805"},{"range":"6806","text":"5710"},"Replace `·musicTrack?.artUrl·||·'https://images.unsplash.com/photo-1614613535308-eb5fbd3d2c17?auto=format&fit=crop&q=80&w=200&h=200'⏎` with `⏎····musicTrack?.artUrl·||⏎····'https://images.unsplash.com/photo-1614613535308-eb5fbd3d2c17?auto=format&fit=crop&q=80&w=200&h=200'`",{"range":"6807","text":"6808"},["6809","6810"],["6811","6812"],["6813","6814"],["6815","6816"],"Replace `·?·`document.querySelector('.next-button')?.click()`` with `⏎······?·`document.querySelector('.next-button')?.click()`⏎·····`",{"range":"6817","text":"6818"},["6819","6820"],"Replace `·?·`document.querySelector('.previous-button')?.click()`` with `⏎······?·`document.querySelector('.previous-button')?.click()`⏎·····`",{"range":"6821","text":"6822"},{"range":"6823","text":"5710"},"React Hook useEffect has a missing dependency: 'toggleMusicPlayer'. Either include it or remove the dependency array.",["6824"],{"range":"6825","text":"5710"},{"range":"6826","text":"6321"},"Replace `{title}` with `⏎················{title}⏎··············`",{"range":"6827","text":"6828"},"Replace `·className=\"absolute·top-0·left-0·h-full·bg-white·transition-all·duration-300·rounded-full·group-hover:bg-[var(--color-accent)]\"·style={{·width:·`${progress}%`·}}` with `⏎················className=\"absolute·top-0·left-0·h-full·bg-white·transition-all·duration-300·rounded-full·group-hover:bg-[var(--color-accent)]\"⏎················style={{·width:·`${progress}%`·}}⏎·············`",{"range":"6829","text":"6830"},"Replace `<Heart·size={16}·/>` with `⏎··············<Heart·size={16}·/>⏎············`",{"range":"6831","text":"6832"},"Replace `·onClick={handleSkipBack}·className=\"text-white/80·hover:text-white·transition-colors\"` with `⏎················onClick={handleSkipBack}⏎················className=\"text-white/80·hover:text-white·transition-colors\"⏎··············`",{"range":"6833","text":"6834"},{"range":"6835","text":"5710"},"Replace `<Pause·size={20}·fill=\"currentColor\"·/>·:·<Play·size={20}·fill=\"currentColor\"·className=\"ml-1\"·/>` with `(⏎··················<Pause·size={20}·fill=\"currentColor\"·/>⏎················)·:·(⏎··················<Play·size={20}·fill=\"currentColor\"·className=\"ml-1\"·/>⏎················)`",{"range":"6836","text":"6837"},"Replace `·onClick={handleSkipForward}·className=\"text-white/80·hover:text-white·transition-colors\"` with `⏎················onClick={handleSkipForward}⏎················className=\"text-white/80·hover:text-white·transition-colors\"⏎··············`",{"range":"6838","text":"6839"},"Replace `<Volume2·size={16}·/>` with `⏎··············<Volume2·size={16}·/>⏎············`",{"range":"6840","text":"6841"},{"range":"6842","text":"5710"},"Replace `\"w-9·h-9·rounded-xl·flex·items-center·justify-center·transition-colors·no-drag·music-trigger\",·isPlaying·?·\"bg-[var(--color-accent)]/10·text-[var(--color-accent)]\"·:·\"hover:bg-white/10·text-text-secondary\"` with `⏎············'w-9·h-9·rounded-xl·flex·items-center·justify-center·transition-colors·no-drag·music-trigger',⏎············isPlaying⏎··············?·'bg-[var(--color-accent)]/10·text-[var(--color-accent)]'⏎··············:·'hover:bg-white/10·text-text-secondary'⏎··········`",{"range":"6843","text":"6844"},"Replace `·animate={{·height:·[4,·12,·4]·}}·transition={{·repeat:·Infinity,·duration:·0.8·}}·className=\"w-[3px]·bg-current·rounded-full\"` with `⏎················animate={{·height:·[4,·12,·4]·}}⏎················transition={{·repeat:·Infinity,·duration:·0.8·}}⏎················className=\"w-[3px]·bg-current·rounded-full\"⏎·············`",{"range":"6845","text":"6846"},"Replace `·animate={{·height:·[8,·4,·8]·}}·transition={{·repeat:·Infinity,·duration:·0.9·}}·className=\"w-[3px]·bg-current·rounded-full\"` with `⏎················animate={{·height:·[8,·4,·8]·}}⏎················transition={{·repeat:·Infinity,·duration:·0.9·}}⏎················className=\"w-[3px]·bg-current·rounded-full\"⏎·············`",{"range":"6847","text":"6848"},"Replace `·animate={{·height:·[6,·10,·6]·}}·transition={{·repeat:·Infinity,·duration:·0.7·}}·className=\"w-[3px]·bg-current·rounded-full\"` with `⏎················animate={{·height:·[6,·10,·6]·}}⏎················transition={{·repeat:·Infinity,·duration:·0.7·}}⏎················className=\"w-[3px]·bg-current·rounded-full\"⏎·············`",{"range":"6849","text":"6850"},{"range":"6851","text":"5710"},"Replace `\"rounded-2xl·bg-white/[0.03]·border·border-white/[0.05]·flex·flex-col·overflow-hidden·transition-colors·cursor-point