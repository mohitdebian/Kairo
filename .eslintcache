.lastActiveAt || Date.now())\n     |                                                                    ^^^^^^^^^^ Cannot call impure function\n  44 |     const hoursAgo = Math.floor(timeDiffMs / (1000 * 60 * 60))\n  45 |     const minutesAgo = Math.floor(timeDiffMs / (1000 * 60))\n  46 |     ",{"range":"6491","text":"5710"},"Replace `!finalUrl.startsWith('http://')·&&·!finalUrl.startsWith('https://')·&&·!finalUrl.includes('localhost')·&&·finalUrl.includes('.')` with `⏎······!finalUrl.startsWith('http://')·&&⏎······!finalUrl.startsWith('https://')·&&⏎······!finalUrl.includes('localhost')·&&⏎······finalUrl.includes('.')⏎····`",{"range":"6492","text":"6493"},"Replace `·searchEngine·===·'google'·⏎` with `⏎········searchEngine·===·'google'⏎··`",{"range":"6494","text":"6495"},{"range":"6496","text":"5937"},{"range":"6497","text":"5710"},"Replace `!url.startsWith('http://')·&&·!url.startsWith('https://')·&&·!url.includes('localhost')·&&·url.includes('.')` with `⏎········!url.startsWith('http://')·&&⏎········!url.startsWith('https://')·&&⏎········!url.includes('localhost')·&&⏎········url.includes('.')⏎······`",{"range":"6498","text":"6499"},"Replace `·searchEngine·===·'google'·` with `⏎··········searchEngine·===·'google'`",{"range":"6500","text":"6501"},"Replace `··········` with `············`",{"range":"6502","text":"5912"},{"range":"6503","text":"5715"},{"range":"6504","text":"5710"},{"range":"6505","text":"5710"},"Delete `⏎········`",{"range":"6506","text":"5710"},{"range":"6507","text":"5710"},"Replace `⏎············What·are·we·working·on·today?⏎··········` with `What·are·we·working·on·today?`",{"range":"6508","text":"6509"},{"range":"6510","text":"5710"},{"range":"6511","text":"5710"},{"range":"6512","text":"5710"},"Replace `·onClick={()·=>·toggleCommandPalette()}·className=\"flex·items-center·gap-1·bg-white/10·rounded·px-2·py-1·text-xs·text-white/70·font-medium·tracking-widest·border·border-white/5·hover:bg-white/20·transition-colors\"` with `⏎··············onClick=