.style.display·=·'none'⏎······················const·next·=·e.currentTarget.nextElementSibling·as·HTMLElement⏎······················if·(next)·next.style.display·=·'flex'⏎····················}}⏎··················`",{"range":"6963","text":"6964"},{"range":"6965","text":"5715"},"Replace `<span·className=\"text-[10px]·uppercase·font-bold\"·style={{·display:·getTabFavicon(tab)·?·'none'·:·'flex'·}}>{getTabTitle(tab).charAt(0)}` with `··<span⏎··················className=\"text-[10px]·uppercase·font-bold\"⏎··················style={{·display:·getTabFavicon(tab)·?·'none'·:·'flex'·}}⏎················>⏎··················{getTabTitle(tab).charAt(0)}⏎················`",{"range":"6966","text":"6967"},{"range":"6968","text":"5715"},{"range":"6969","text":"5715"},{"range":"6970","text":"5715"},{"range":"6971","text":"5715"},{"range":"6972","text":"5715"},{"range":"6973","text":"6046"},{"range":"6974","text":"5715"},"Replace `····<div·⏎······onClick={onClick}·` with `······<div⏎········onClick={onClick}`",{"range":"6975","text":"6976"},{"range":"6977","text":"5717"},{"range":"6978","text":"5715"},{"range":"6979","text":"5715"},{"range":"6980","text":"5715"},{"range":"6981","text":"5715"},"Replace `\"flex·items-center·gap-2·px-3·py-2·rounded-xl·transition-all·cursor-pointer·relative·group\",·⏎········isActive·?·\"bg-[var(--color-accent)]/15·text-white·font-medium\"·:·\"hover:bg-white/5·text-text-secondary·hover:text-text-primary·font-medium\"` with `··'flex·items-center·gap-2·px-3·py-2·rounded-xl·transition-all·cursor-pointer·relative·group',⏎··········isActive⏎············?·'bg-[var(--color-accent)]/15·text-white·font-medium'⏎············:·'hover:bg-white/5·text-text-secondary·hover:text-text-primary·font-medium'`",{"range":"6982","text":"6983"},"Replace `········isDragging·&&·\"opacity-50·z-10\"` with `··········isDragging·&&·'opacity-50·z-10'`",{"range":"6984","text":"6985"},"Replace `hoverSide·===·'top'·&&·\"shadow-[0_-2px_0_0_var(--color-accent)]\"` with `··hoverSide·===·'top'·&&·