ndex·+·1])` with `⏎········newSizes[index]·+·newSizes[index·+·1]`",{"range":"6282","text":"6283"},{"range":"6284","text":"5716"},{"range":"6285","text":"5716"},{"range":"6286","text":"5716"},{"range":"6287","text":"5716"},{"range":"6288","text":"5716"},"Replace `\"absolute·z-50·flex·items-center·justify-center\"` with `'absolute·z-50·flex·items-center·justify-center'`",{"range":"6289","text":"6290"},"Replace `\"w-2·cursor-col-resize·-ml-1\"·:·\"h-2·cursor-row-resize·-mt-1\"` with `'w-2·cursor-col-resize·-ml-1'·:·'h-2·cursor-row-resize·-mt-1'`",{"range":"6291","text":"6292"},{"range":"6293","text":"5716"},"Insert `⏎·······`",{"range":"6294","text":"6295"},"Replace `········\"absolute·bg-white/10·transition-all·hover:bg-[var(--color-accent)]/50·rounded-full\"` with `··········'absolute·bg-white/10·transition-all·hover:bg-[var(--color-accent)]/50·rounded-full'`",{"range":"6296","text":"6297"},"Replace `········isHorizontal·?·\"w-[3px]·h-full\"·:·\"h-[3px]·w-full\"` with `··········isHorizontal·?·'w-[3px]·h-full'·:·'h-[3px]·w-full'`",{"range":"6298","text":"6299"},"Replace `······)}` with `········)}⏎·····`",{"range":"6300","text":"6301"},{"range":"6302","text":"6168"},{"range":"6303","text":"6170"},{"range":"6304","text":"6168"},{"range":"6305","text":"6168"},{"range":"6306","text":"6170"},{"range":"6307","text":"6168"},"React Hook useEffect has a missing dependency: 'toggleCommandPalette'. Either include it or remove the dependency array.",["6308"],"Replace `·query.includes('.')·&&·!query.includes('·')·?·`Open·${query.startsWith('http')·?·query·:·`https://${query}`}`` with `⏎········query.includes('.')·&&·!query.includes('·')⏎··········?·`Open·${query.startsWith('http')·?·query·:·`https://${query}`}`⏎·········`",{"range":"6309","text":"6310"},"Replace `!url.startsWith('http://')·&&·!url.startsWith('https://')·&&·!url.includes('localhost')·&&·url.includes('.')` with `⏎··········!url.startsWith('http://')·&&⏎··········!url.startsWith('https://')·&&⏎··········!url.includes('localhost')·&&⏎··········url.includes('.')⏎········`",{"range":"6311","text":"6312"},"Insert `⏎···········`",{"range":"6313","text":"6314"},{"range":"6315","text":"5721"},{"range":"6316","text":"5985"},"Replace `ws` with `(ws)`",{"range":"6317","text":"6318"},"Replace `·query.length·>·0·⏎····?·actions.filter(a·=>·a.title.toLowerCase().includes(query.toLowerCase())·||·a.type·===·'Navigation'` with `⏎····query.length·>·0⏎······?·actions.filter(⏎··········(a)·=>·a.title.toLowerCase().includes(query.toLowerCase())·||·a.type·===·'Navigation'⏎········`",{"range":"6319","text":"6320"},"Replace `····:·actions.filter(a` with `······:·actions.filter((a)`",{"range":"6321","text":"6322"},"react-hooks/set-state-in-effect","Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/tmp/workspace/mohitdebian/Kairo/src/renderer/src/components/CommandPalette/CommandPalette.tsx:90:5\n  88 |\n  89 |   useEffect(() => {\n> 90 |     setSelectedIndex(0)\n     |     ^^^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  91 |   }, [query])\n  92 |\n  93 |   const handleKeyDown = (e: React.KeyboardEvent) => {","Replace `prev` with `(prev)`",{"range":"6323","text":"6324"},{"range":"6325","text":"6324"},"Replace `\"easeOut\"` with `'easeOut'`",{"range":"6326","text":"6327"},"Replace `\"flex·items-center·gap-3·px-3·py-3·rounded-xl·cursor-pointer·transition-colors\"` with `'flex·items-center·gap-3·px-3·py-3·rounded-xl·cursor-pointer·transition-colors'`",{"range":"6328","text":"6329"},"Replace `·?·\"bg-accent/20·text-text-primary\"·:·\"text-text-secondary·hover:bg-white/5\"` with `⏎····························?·'bg-accent/20·text-text-primary'⏎····························:·'text-text-secondary·hover:bg-white/5'`",{"range":"6330","text":"6331"},"Replace `·size={18}·className={cn(isSelected·?·\"text-accent\"·:·\"text-text-secondary\")}` with `⏎··························size={18}⏎··························className={cn(isSelected·?·'text-accent'·:·'text-text-secondary')}⏎·······················`",{"range":"6332","text":"6333"},{"range":"6334","text":"5716"},"Replace `ENTER` with `⏎··················ENTER⏎················`",{"range":"6335","text":"6336"},{"range":"6337","text":"5716"},"Replace `·Link,·Copy,·Image·as·ImageIcon,·Download,·` with `⏎··Link,⏎··Copy,⏎··Image·as·ImageIcon,⏎··Download,`",{"range":"6338","text":"6339"},"Replace `·VolumeX,·Repeat,` with `⏎··VolumeX,⏎··Repeat,⏎·`",{"range":"6340","text":"6341"},"Replace `·ClipboardPaste,·Search,` with `⏎··ClipboardPaste,⏎··Search,⏎·`",{"range":"6342","text":"6343"},"Replace `·FolderPlus,·MonitorUp,·Languages,·Sparkles,·` with `⏎··FolderPlus,⏎··MonitorUp,⏎··Languages,⏎··Sparkles,`",{"range":"6344","text":"6345"},"'MonitorUp' is defined but never used.",["6346"],"Replace `·RefreshCw,·FileCode,·Terminal,·ArrowLeft,·ArrowRight,` with `⏎··RefreshCw,⏎··FileCode,⏎··Terminal,⏎··ArrowLeft,⏎··ArrowRight,⏎·`",{"range":"6347","text":"6348"},"Replace `ContextMenuParams·&·{·x:·number,·y:·number·}` with `(ContextMenuParams·&·{·x:·number;·y:·number·})`",{"range":"6349","text":"6350"},["6351","6352"],{"range":"6353","text":"5838"},{"range":"6354","text":"5716"},{"range":"6355","text":"5716"},{"range":"6356","text":"5716"},"Replace `·key=\"link-open\"·icon={<ExternalLink·size={14}/>}·label=\"Open·Link\"·onClick={()·=>·executeAction('open-link')}` with `⏎··········key=\"link-open\"⏎··········icon={<ExternalLink·size={14}·/>}⏎··········label=\"Open·Link\"⏎··········onClick={()·=>·executeAction('open-link')}⏎·······`",{"range":"6357","text":"6358"},"Replace `·key=\"link-tab\"·icon={<Plus·size={14}/>}·label=\"Open·Link·in·New·Tab\"·onClick={()·=>·executeAction('open-link-new-tab')}` with `⏎··········key=\"link-tab\"⏎··········icon={<Plus·size={14}·/>}⏎··········label=\"Open·Link·in·New·Tab\"⏎··········onClick={()·=>·executeAction('open-link-new-tab')}⏎·······`",{"range":"6359","text":"6360"},"Replace `·key=\"link-bg-tab\"·icon={<Copy·size={14}/>}·label=\"Open·in·Background·Tab\"·onClick={()·=>·executeAction('open-link-bg-tab')}` with `⏎··········key=\"link-bg-tab\"⏎··········icon={<Copy·size={14}·/>}⏎··········label=\"Open·in·Background·Tab\"⏎··········onClick={()·=>·executeAction('open-link-bg-tab')}⏎·······`",{"range":"6361","text":"6362"},"Replace `·key=\"link-win\"·icon={<PanelRight·size={14}/>}·label=\"Open·Link·in·New·Window\"·onClick={()·=>·executeAction('open-link-new-window')}` with `⏎··········key=\"link-win\"⏎··········icon={<PanelRight·size={14}·/>}⏎··········label=\"Open·Link·in·New·Window\"⏎··········onClick={()·=>·executeAction('open-link-new-window')}⏎·······`",{"range":"6363","text":"6364"},{"range":"6365","text":"6318"},"Replace `·key={`link-ws-${ws.id}`}·icon={<div·className=\"w-3·h-3·rounded-full\"·style={{backgroundColor:·ws.color}}/>}·label={`Open·in·${ws.name}`}` with `⏎··············key={`link-ws-${ws.id}`}⏎··············icon={<div·className=\"w-3·h-3·rounded-full\"·style={{·backgroundColor:·ws.color·}}·/>}⏎··············label={`Open·in·${ws.name}`}⏎·············`",{"range":"6366","text":"6367"},"Replace `··············window.electron.ipcRenderer.send('context-menu-action',·'open-link-in-space',·params.tabId,·{·...params,·spaceId:·ws.id·}` with `················window.electron.ipcRenderer.send(⏎··················'context-menu-action',⏎··················'open-link-in-space',⏎··················params.tabId,⏎··················{·...params,·spaceId:·ws.id·}⏎················`",{"range":"6368","text":"6369"},{"range":"6370","text":"5721"},"Replace `}}` with `··}}⏎···········`",{"range":"6371","text":"6372"},"Replace `·key=\"copy-link\"·icon={<Link·size={14}/>}·label=\"Copy·Link\"·onClick={()·=>·executeAction('copy-link')}` with `⏎··········key=\"copy-link\"⏎··········icon={<Link·size={14}·/>}⏎··········label=\"Copy·Link\"⏎··········onClick={()·=>·executeAction('copy-link')}⏎·······`",{"range":"6373","text":"6374"},"Replace `·key=\"copy-link-address\"·icon={<Copy·size={14}/>}·label=\"Copy·Link·Address\"·onClick={()·=>·executeAction('copy-link')}` with `⏎··········key=\"copy-link-address\"⏎··········icon={<Copy·size={14}·/>}⏎··········label=\"Copy·Link·Address\"⏎··········onClick={()·=>·executeAction('copy-link')}⏎·······`",{"range":"6375","text":"6376"},"Replace `·key=\"bookmark-link\"·icon={<Bookmark·size={14}/>}·label=\"Bookmark·Link\"·onClick={()·=>·executeAction('bookmark-link')}` with `⏎··········key=\"bookmark-link\"⏎··········icon={<Bookmark·size={14}·/>}⏎··········label=\"Bookmark·Link\"⏎··········onClick={()·=>·executeAction('bookmark-link')}⏎·······`",{"range":"6377","text":"6378"},"Replace `·key=\"save-link\"·icon={<Save·size={14}/>}·label=\"Save·Link·As...\"·onClick={()·=>·executeAction('save-link')}` with `⏎··········key=\"save-link\"⏎··········icon={<Save·size={14}·/>}⏎··········label=\"Save·Link·As...\"⏎··········onClick={()·=>·executeAction('save-link')}⏎·······`",{"range":"6379","text":"6380"},"Replace `·key=\"img-tab\"·icon={<ImageIcon·size={14}/>}·label=\"Open·Image·in·New·Tab\"·onClick={()·=>·executeAction('open-image-new-tab')}` with `⏎··········key=\"img-tab\"⏎··········icon={<ImageIcon·size={14}·/>}⏎··········label=\"Open·Image·in·New·Tab\"⏎··········onClick={()·=>·executeAction('open-image-new-tab')}⏎·······`",{"range":"6381","text":"6382"},"Replace `·key=\"save-img\"·icon={<Download·size={14}/>}·label=\"Save·Image·As...\"·onClick={()·=>·executeAction('save-im