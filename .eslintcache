enter·justify-center\"` with `'absolute·z-50·flex·items-center·justify-center'`",{"range":"6283","text":"6284"},"Replace `\"w-2·cursor-col-resize·-ml-1\"·:·\"h-2·cursor-row-resize·-mt-1\"` with `'w-2·cursor-col-resize·-ml-1'·:·'h-2·cursor-row-resize·-mt-1'`",{"range":"6285","text":"6286"},{"range":"6287","text":"5710"},"Insert `⏎·······`",{"range":"6288","text":"6289"},"Replace `········\"absolute·bg-white/10·transition-all·hover:bg-[var(--color-accent)]/50·rounded-full\"` with `··········'absolute·bg-white/10·transition-all·hover:bg-[var(--color-accent)]/50·rounded-full'`",{"range":"6290","text":"6291"},"Replace `········isHorizontal·?·\"w-[3px]·h-full\"·:·\"h-[3px]·w-full\"` with `··········isHorizontal·?·'w-[3px]·h-full'·:·'h-[3px]·w-full'`",{"range":"6292","text":"6293"},"Replace `······)}` with `········)}⏎·····`",{"range":"6294","text":"6295"},{"range":"6296","text":"6162"},{"range":"6297","text":"6164"},{"range":"6298","text":"6162"},{"range":"6299","text":"6162"},{"range":"6300","text":"6164"},{"range":"6301","text":"6162"},"React Hook useEffect has a missing dependency: 'toggleCommandPalette'. Either include it or remove the dependency array.",["6302"],"Replace `·query.includes('.')·&&·!query.includes('·')·?·`Open·${query.startsWith('http')·?·query·:·`https://${query}`}`` with `⏎········query.includes('.')·&&·!query.includes('·')⏎··········?·`Open·${query.startsWith('http')·?·query·:·`https://${query}`}`⏎·········`",{"range":"6303","text":"6304"},"Replace `!url.startsWith('http://')·&&·!url.startsWith('https://')·&&·!url.includes('localhost')·&&·url.includes('.')` with `⏎··········!url.startsWith('http://')·&&⏎··········!url.startsWith('https://')·&&⏎··········!url.includes('localhost')·&&⏎··········url.includes('.')⏎········`",{"range":"6305","text":"6306"},"Insert `⏎···········`",{"range":"6307","text":"6308"},{"range":"6309","text":"5715"},{"range":"6310","text":"5979"},"Replace `ws` with `(ws)`",{"range":"6311","text":"6312"},"Replace `·query.length·>·0·⏎····?·actions.filter(a·=>·a.title.toLowerCase().includes(query.toLowerCase())·||·a.type·===·'Navigation'` with `⏎····query.length·>·0⏎······?·actions.filter(⏎··········(a)·=>·a.title.toLowerCase().includes(query.toLowerCase())·||·a.type·===·'Navigation'⏎········`",{"range":"6313","text":"6314"},"Replace `····:·actions.filter(a` with `······:·actions.filter((a)`",{"range":"6315","text":"6316"},"react-hooks/set-state-in-effect","Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/tmp/workspace/mohitdebian/Kairo/src/renderer/src/components/CommandPalette/CommandPalette.tsx:90:5\n  88 |\n  89 |   useEffect(() => {\n> 90 |     setSelectedIndex(0)\n     |     ^^^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  91 |   }, [query])\n  92 |\n  93 |   const handleKeyDown = (e: React.KeyboardEvent) => {","Replace `prev` with `(prev)`",{"range":"6317","text":"6318"},{"range":"6319","text":"6318"},"Replace `\"easeOut\"` with `'easeOut'`",{"range":"6320","text":"6321"},"Replace `\"flex·items-center·gap-3·px-3·py-3·rounded-xl·cursor-pointer·transition-colors\"` with `'flex·items-center·gap-3·px-3·py-3·rounded-xl·cursor-pointer·transition-colors'`",{"range":"6322","text":"6323"},"Replace `·?·\"bg-accent/20·text-text-primary\"·:·\"text-text-secondary·hover:bg-white/5\"` with `⏎····························?·'bg-accent/20·text-text-primary'⏎····························:·'text-text-secondary·hover:bg-white/5'`",{"range":"6324","text":"6325"},"Replace `·size={18}·className={cn(isSelected·?·\"text-accent\"·:·\"text-text-secondary\")}` with `⏎··························size={18}⏎··························className={cn(isSelected·?·'text-accent'·:·'text-text-secondary')}⏎·······················`",{"range":"6326","text":"6327"},{"range":"6328","text":"5710"},"Replace `ENTER` with `⏎··················ENTER⏎················`",{"range":"6329","text":"6330"},{"range":"6331","text":"5710"},"Replace `·Link,·Copy,·Image·as·ImageIcon,·Download,·` with `⏎··Link,⏎··Copy,⏎··Image·as·ImageIcon,⏎··Download,`",{"range":"6332","text":"6333"},"Replace `·VolumeX,·Repeat,` with `⏎··VolumeX,⏎··Repeat,⏎·`",{"range":"6334","text":"6335"},"Replace `·ClipboardPaste,·Search,` with `⏎··ClipboardPaste,⏎··Search,⏎·`",{"range":"6336","text":"6337"},"Replace `·FolderPlus,·MonitorUp,·Languages,·Sparkles,·` with `⏎··FolderPlus,⏎··MonitorUp,⏎··Languages,⏎··Sparkles,`",{"range":"6338","text":"6339"},"'MonitorUp' is defined but never used.",["6340"],"Replace `·RefreshCw,·FileCode,·Terminal,·ArrowLeft,·ArrowRight,` with `⏎··RefreshCw,⏎··FileCode,⏎··Terminal,⏎··ArrowLeft,⏎··ArrowRight,⏎·`",{"range":"6341","text":"6342"},"Replace `ContextMenuParams·&·{·x:·number,·y:·number·}` with `(ContextMenuParams·&·{·x:·number;·y:·number·})`",{"range":"6343","text":"6344"},["6345","6346"],{"range":"6347","text":"5832"},{"range":"6348","text":"5710"},{"range":"6349","text":"5710"},{"range":"6350","text":"5710"},"Replace `·key=\"link-open\"·icon={<ExternalLink·size={14}/>}·label=\"Open·Link\"·onClick={()·=>·executeAction('open-link')}` with `⏎··········key=\"link-open\"⏎··········icon={<ExternalLink·size={14}·/>}⏎··········label=\"Open·Link\"⏎··········onClick={()·=>·executeAction('open-link')}⏎·······`",{"range":"6351","text":"6352"},"Replace `·key=\"link-tab\"·icon={<Plus·size={14}/>}·label=\"Open·Link·in·New·Tab\"·onClick={()·=>·executeAction('open-link-new-tab')}` with `⏎··········key=\"link-tab\"⏎··········icon={<Plus·size={14}·/>}⏎··········label=\"Open·Link·in·New·Tab\"⏎··········onClick={()·=>·executeAction('open-link-new-tab')}⏎·······`",{"range":"6353","text":"6354"},"Replace `·key=\"link-bg-tab\"·icon={<Copy·size={14}/>}·label=\"Open·in·Background·Tab\"·onClick={()·=>·executeAction('open-link-bg-tab')}` with `⏎··········key=\"link-bg-tab\"⏎··········icon={<Copy·size={14}·/>}⏎··········label=\"Open·in·Background·Tab\"⏎··········onClick={()·=>·executeAction('open-link-bg-tab')}⏎·······`",{"range":"6355","text":"6356"},"Replace `·key=\"link-win\"·icon={<PanelRight·size={14}/>}·label=\"Open·Link·in·New·Window\"·onClick={()·=>·executeAction('open-link-new-window')}` with `⏎··········key=\"link-win\"⏎··········icon={<PanelRight·size={14}·/>}⏎··········label=\"Open·Link·in·New·Window\"⏎··········onClick={()·=>·executeAction('open-link-new-window')}⏎·······`",{"range":"6357","text":"6358"},{"range":"6359","text":"6312"},"Replace `·key={`link-ws-${ws.id}`}·icon={<div·className=\"w-3·h-3·rounded-full\"·style={{backgroundColor:·ws.color}}/>}·label={`Open·in·${ws.name}`}` with `⏎··············key={`link-ws-${ws.id}`}⏎··············icon={<div·className=\"w-3·h-3·rounded-full\"·style={{·backgroundColor:·ws.color·}}·/>}⏎··············label={`Open·in·${ws.name}`}⏎·············`",{"range":"6360","text":"6361"},"Replace `··············window.electron.ipcRenderer.send('context-menu-action',·'open-link-in-space',·params.tabId,·{·...params,·spaceId:·ws.id·}` with `················window.electron.ipcRenderer.send(⏎··················'context-menu-action',⏎··················'open-link-in-space',⏎··················params.tabId,⏎··················{·...params,·spaceId:·ws.id·}⏎················`",{"range":"6362","text":"6363"},{"range":"6364","text":"5715"},"Replace `}}` with `··}}⏎···········`",{"range":"6365","text":"6366"},"Replace `·key=\"copy-link-address\"·icon={<Link·size={14}/>}·label=\"Copy·Link·Address\"·onClick={()